{
	"name": "bedigit/laraclassified",
	"description": "Geo Classified Ads CMS.",
	"keywords": ["ads", "classified", "cms", "laravel", "php"],
	"license": "Envato",
	"type": "project",
	"require": {
		"php": "^8.2",
		"aws/aws-sdk-php": "^3.0",
		"chriskonnertz/open-graph": "^2.0",
		"cocur/slugify": "^4.0",
		"creativeorange/gravatar": "~1.0",
		"cviebrock/eloquent-sluggable": "^12.0",
		"guzzlehttp/guzzle": "^7.0",
		"intervention/image": "^3.0",
		"jaybizzle/crawler-detect": "^1.4",
		"jaybizzle/laravel-crawler-detect": "^1.3",
		"lab404/laravel-impersonate": "^1.7",
		"laracasts/flash": "^3.2",
		"laravel-notification-channels/twilio": "^4.0",
		"laravel/framework": "^12.0",
		"laravel/passport": "^12.0",
		"laravel/socialite": "^5.0",
		"laravel/ui": "^4.6",
		"league/csv": "^9.1",
		"maatwebsite/excel": "^3.1",
		"mcamara/laravel-localization": "^2.4",
		"mews/purifier": "^3.0",
		"nesbot/carbon": "^3.8",
		"omnipay/paypal": "~3.0",
		"omnipay/stripe": "~3.0",
		"prologue/alerts": "^1.4",
		"propaganistas/laravel-phone": "^5.0",
		"spatie/laravel-backup": "^9.0",
		"spatie/laravel-cookie-consent": "^3.0",
		"spatie/laravel-feed": "^4.0",
		"torann/geoip": "^3.0",
		"torann/laravel-meta-tags": "^3.0",
		"vonage/client": "^4.0",
		"watson/sitemap": "^5.0"
	},
	"require-dev": {
		"fakerphp/faker": "^1.23",
		"filp/whoops": "^2.15",
		"mockery/mockery": "^1.6",
		"nunomaduro/collision": "^8.0",
		"phpunit/phpunit": "^11.0"
	},
	"autoload": {
		"files": [
			"app/Helpers/Functions/admin.php",
			"app/Helpers/Functions/core.php",
			"app/Helpers/Functions/plugin.php",
			"app/Helpers/Functions/wordpress.php"
		],
		"classmap": [
			"packages/mcamara/laravel-localization/src/Traits"
		],
		"psr-4": {
			"App\\": "app/",
			"App\\Observer\\": "app/Observers/",
			"LarapenIlluminate\\": "packages/laravel/framework/src/Illuminate/",
			"Larapen\\TextToImage\\": "packages/larapen/texttoimage/src/",
			"Larapen\\LaravelLocalization\\": "packages/mcamara/laravel-localization/src/",
			"Larapen\\LaravelMetaTags\\": "packages/torann/laravel-meta-tags/src/",
			"Larapen\\Admin\\": "packages/larapen/admin/src/",
			"Larapen\\Feed\\": "packages/spatie/laravel-feed/src/",
			"Larapen\\Impersonate\\": "packages/lab404/laravel-impersonate/src/"
		}
	},
	"autoload-dev": {},
	"extra": {
		"laravel": {
			"dont-discover": [
				"lab404/laravel-impersonate",
				"mcamara/laravel-localization",
				"spatie/laravel-feed"
			]
		}
	},
	"scripts": {
		"post-root-package-install": [
			"@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
		],
		"post-create-project-cmd": [
			"@php artisan key:generate"
		],
		"post-autoload-dump": [
			"Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
			"@php artisan package:discover --ansi"
		]
	},
	"config": {
		"preferred-install": "dist",
		"sort-packages": true,
		"optimize-autoloader": true,
		"allow-plugins": {
			"kylekatarnls/update-helper": true,
			"composer/package-versions-deprecated": true
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true
}
